{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "estimate.intake",
  "type": "object",
  "required": ["kind", "version", "id", "title", "summary", "goals", "constraints", "acceptance", "files"],
  "properties": {
    "kind": { "const": "estimate.intake" },
    "version": { "const": 1 },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "goals": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
