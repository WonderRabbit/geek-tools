{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [".opencode/codegraph/runtime/current/node/node.exe", ".opencode/codegraph/scripts/mcp-proxy.mjs"],
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "wonder_codegraph_*": "allow",
    "codegraph_*": "ask"
  }
}
