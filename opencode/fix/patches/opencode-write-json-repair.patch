+++ b/packages/opencode/test/session/tool-call-diagnostics.test.ts
@@ -0,0 +1,48 @@
+import { describe, expect, test } from "bun:test"
+import { summarizeToolCallInput } from "../../src/session/tool-call-diagnostics"
+
+describe("tool-call diagnostics", () => {
+  test("classifies Text brace as truncated_json", () => {
+    const diagnostic = summarizeToolCallInput("{", ["filePath", "content"])
+
+    expect(diagnostic.kind).toBe("truncated_json")
+    expect(diagnostic.rawSnippet).toBe("{")
+    expect(diagnostic.receivedKeys).toEqual([])
+  })
+
+  test("classifies tool-call tail text as extra_text", () => {
+    const diagnostic = summarizeToolCallInput('{"filePath":"/tmp/a.md","content":"ok"}</tool_call>', [
+      "filePath",
+      "content",
+    ])
+
+    expect(diagnostic.kind).toBe("extra_text")
+  })
+
+  test("classifies valid JSON with missing write keys as schema_missing_key", () => {
+    const diagnostic = summarizeToolCallInput('{"content":"# Title"}', ["filePath", "content"])
+
+    expect(diagnostic.kind).toBe("schema_missing_key")
+    expect(diagnostic.receivedKeys).toEqual(["content"])
+  })
+
+  test("keeps valid escaped Markdown content unknown to schema errors", () => {
+    const diagnostic = summarizeToolCallInput('{"filePath":"/tmp/a.md","content":"# Title\\n```json\\n{}\\n```"}', [
+      "filePath",
+      "content",
+    ])
+
+    expect(diagnostic.kind).toBe("unknown")
+    expect(diagnostic.receivedKeys).toEqual(["content", "filePath"])
+  })
+
+  test("bounds and redacts raw snippets", () => {
+    const diagnostic = summarizeToolCallInput(
+      `{"apiKey":"secret","content":"${"x".repeat(400)}"`,
+      ["filePath", "content"],
+    )
+
+    expect(diagnostic.rawSnippet).toContain("[redacted]")
+    expect(diagnostic.rawSnippet.length).toBeLessThanOrEqual(243)
+  })
+})
