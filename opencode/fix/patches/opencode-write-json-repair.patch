+type WriteRepairInput = {
+  readonly abort: AbortSignal
+  readonly error: string
+  readonly messages: readonly ModelMessage[]
+  readonly model: Parameters<typeof generateText>[0]["model"]
+  readonly rawSnippet: string
+  readonly tool: Tool | undefined
+}
+
+type WriteRepairArgs = {
+  readonly filePath: string
+  readonly content: string
+}
+
+function shouldRepairWriteToolCall(error: string) {
+  return /InvalidToolInputError|JSON parsing failed|Invalid tool input|Schema/i.test(error)
+}
+
+async function yieldWriteRepair(input: WriteRepairInput): Promise<WriteRepairArgs | undefined> {
+  if (!input.tool) return undefined
+  const prompt = [
+    "Repair the failed OpenCode write tool call.",
+    "Return a write tool call with exactly these string keys: filePath, content.",
+    "Do not invent another tool name. Do not add alias keys such as path or fileContent.",
+    `Original parser error: ${input.error}`,
+    `Original raw input snippet: ${input.rawSnippet}`,
+  ].join("\n")
+  const result = await generateText({
+    abortSignal: input.abort,
+    maxOutputTokens: WRITE_REPAIR_MAX_OUTPUT_TOKENS,
+    messages: [...input.messages, { role: "user", content: prompt.slice(0, WRITE_REPAIR_MAX_PROMPT_CHARS) }],
+    model: input.model,
+    tools: { write: stripToolExecution(input.tool) },
+  })
+  const repaired = result.toolCalls.find((toolCall) => toolCall.toolName === WRITE_TOOL_NAME)
+  if (!repaired || !isWriteRepairArgs(repaired.input)) return undefined
+  return repaired.input
+}
+
+function isWriteRepairArgs(value: unknown): value is WriteRepairArgs {
+  if (typeof value !== "object" || value === null || Array.isArray(value)) return false
+  if (!("filePath" in value) || !("content" in value)) return false
+  return typeof value.filePath === "string" && typeof value.content === "string"
+}
+
+function stripToolExecution(tool: Tool): Tool {
+  const { execute: _execute, ...schemaOnlyTool } = tool
+  return schemaOnlyTool
+}
+
