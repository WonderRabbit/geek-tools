index 0000000..abffe58
--- /dev/null
+++ b/packages/opencode/src/session/tool-call-diagnostics.ts
@@ -0,0 +1,93 @@
+export const TOOL_CALL_DIAGNOSTIC_KIND = {
+  truncatedJson: "truncated_json",
+  invalidJson: "invalid_json",
+  extraText: "extra_text",
+  schemaMissingKey: "schema_missing_key",
+  schemaWrongType: "schema_wrong_type",
+  unknown: "unknown",
+} as const
+
+export type ToolCallDiagnosticKind =
+  (typeof TOOL_CALL_DIAGNOSTIC_KIND)[keyof typeof TOOL_CALL_DIAGNOSTIC_KIND]
+
+export type ToolCallDiagnostic = {
+  readonly kind: ToolCallDiagnosticKind
+  readonly rawSnippet: string
+  readonly receivedKeys: readonly string[]
+}
+
+export const MAX_DIAGNOSTIC_CHARS = 240
+export const MAX_DIAGNOSTIC_LINES = 4
+
+export function summarizeToolCallInput(input: unknown, expectedKeys: readonly string[] = []): ToolCallDiagnostic {
+  const raw = rawToolInput(input)
+  const rawSnippet = redactToolCallInput(raw)
+  const parsed = parseJson(raw)
+  if (parsed.ok) {
+    if (!isRecord(parsed.value)) {
+      return { kind: TOOL_CALL_DIAGNOSTIC_KIND.schemaWrongType, rawSnippet, receivedKeys: [] }
+    }
+    const receivedKeys = Object.keys(parsed.value).sort()
+    const missing = expectedKeys.filter((key) => !(key in parsed.value))
+    if (missing.length > 0) {
+      return { kind: TOOL_CALL_DIAGNOSTIC_KIND.schemaMissingKey, rawSnippet, receivedKeys }
+    }
+    const wrongType = expectedKeys.some((key) => typeof parsed.value[key] !== "string")
+    return {
+      kind: wrongType ? TOOL_CALL_DIAGNOSTIC_KIND.schemaWrongType : TOOL_CALL_DIAGNOSTIC_KIND.unknown,
+      rawSnippet,
+      receivedKeys,
+    }
+  }
+
+  return {
+    kind: classifyJsonFailure(raw, parsed.error),
+    rawSnippet,
+    receivedKeys: [],
+  }
+}
+
+export function redactToolCallInput(raw: string): string {
+  const redacted = raw.replace(
+    /("(?:api[_-]?key|authorization|token|password|secret)"\s*:\s*")[^"]*(")/giu,
+    "$1[redacted]$2",
+  )
+  const lines = redacted.split(/\r?\n/u).slice(0, MAX_DIAGNOSTIC_LINES)
+  const snippet = lines.join("\n")
+  return snippet.length > MAX_DIAGNOSTIC_CHARS ? `${snippet.slice(0, MAX_DIAGNOSTIC_CHARS)}...` : snippet
+}
+
+function rawToolInput(input: unknown): string {
+  if (typeof input === "string") return input
+  try {
+    return JSON.stringify(input)
+  } catch (error) {
+    if (error instanceof TypeError) return String(input)
+    throw error
+  }
+}
+
+type ParseResult = { readonly ok: true; readonly value: unknown } | { readonly ok: false; readonly error: SyntaxError }
+
+function parseJson(raw: string): ParseResult {
+  try {
+    return { ok: true, value: JSON.parse(raw) }
+  } catch (error) {
+    if (error instanceof SyntaxError) return { ok: false, error }
+    throw error
+  }
+}
+
+function classifyJsonFailure(raw: string, error: SyntaxError): ToolCallDiagnosticKind {
+  const trimmed = raw.trim()
+  if (trimmed.includes("</tool_call>")) return TOOL_CALL_DIAGNOSTIC_KIND.extraText
+  if (trimmed === "{" || trimmed === "[" || /unexpected end|unterminated|expected '?\}|'?\]/iu.test(error.message)) {
+    return TOOL_CALL_DIAGNOSTIC_KIND.truncatedJson
+  }
+  if (!trimmed.startsWith("{") && !trimmed.startsWith("[")) return TOOL_CALL_DIAGNOSTIC_KIND.extraText
+  return TOOL_CALL_DIAGNOSTIC_KIND.invalidJson
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value)
+}
